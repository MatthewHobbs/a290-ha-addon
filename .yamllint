extends: default
# Bundled dashboard assets are upstream HA/Lovelace YAML (Topolino-derived), not add-on
# config we author — don't hold them to the add-on's lint rules.
ignore: |
  alpine_a290/dashboards/
rules:
  line-length: disable
  document-start: disable
  truthy:
    allowed-values: ['true', 'false']
    check-keys: false
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable
  braces:
    max-spaces-inside: 1
  indentation:
    spaces: 2
    indent-sequences: whatever
